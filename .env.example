# Neural Recruiter Configuration
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to version control

# Google Gemini API Key (for LLM-powered JD parsing & candidate critique)
# Get your free API key from: https://ai.google.dev/
GEMINI_API_KEY="your_gemini_api_key_here"

# Optional: Google Cloud project number (for reference)
# GEMINI_PROJECT_ID="266378026137"

# Optional: path to official candidate dataset (CSV or JSONL)
# CANDIDATES_FILE="candidates.csv"

# Optional: Feature flags
# DISABLE_SEMANTIC_RERANKING=false
# DISABLE_HONEYPOT_DETECTION=false
